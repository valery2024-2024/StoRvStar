@model StoRvStar.Models.ViewModels.CreateServiceRequestVM
@using System.Text.Json

<div class="container mt-4">
    <h2 class="mb-4">Створити заявку</h2>

    <form method="post" class="card p-4 shadow">

        <div class="mb-3">
            <label class="form-label">Клієнт</label>
            <select asp-for="SelectedUserId" class="form-select" id="userSelect" required>
                <option value="">Виберіть клієнта</option>
                @foreach (var user in Model.Users)
                {
                    <option value="@user.Id">@user.Name (@user.Phone)</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Авто</label>
            <select asp-for="SelectedCarId" class="form-select" id="carSelect" required>
                <option value="">Виберіть авто</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Послуги</label>

            @foreach (var service in Model.Services)
            {
                <div class="form-check">
                    <input class="form-check-input service-checkbox"
                           type="checkbox"
                           name="SelectedServiceIds"
                           value="@service.Id"
                           data-price="@service.Price" />

                    <label class="form-check-label">
                        @service.Name (@service.Price грн)
                    </label>
                </div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Опис</label>
            <input asp-for="Description" class="form-control" />
        </div>

        <div class="mb-3">
            <h4>💰 Сума: <span id="total">0</span> грн</h4>
        </div>

        <button type="submit" class="btn btn-success">
            Створити
        </button>

    </form>
</div>

<script>
    const checkboxes = document.querySelectorAll('.service-checkbox');
    const totalEl = document.getElementById('total');
    const userSelect = document.getElementById('userSelect');
    const carSelect = document.getElementById('carSelect');

    const allCars = @Html.Raw(JsonSerializer.Serialize(
        Model.Cars.Select(c => new
        {
            id = c.Id,
            brand = c.Brand,
            model = c.Model,
            plateNumber = c.PlateNumber,
            userId = c.UserId
        })
    ));

    function updateTotal() {
        let total = 0;

        checkboxes.forEach(c => {
            if (c.checked) {
                total += parseFloat(c.dataset.price);
            }
        });

        totalEl.textContent = total;
    }

    checkboxes.forEach(cb => {
        cb.addEventListener('change', updateTotal);
    });

    userSelect.addEventListener('change', function () {
        const userId = parseInt(this.value);

        carSelect.innerHTML = '<option value="">Виберіть авто</option>';

        if (!userId) return;

        const filteredCars = allCars.filter(c => c.userId === userId);

        filteredCars.forEach(car => {
            const option = document.createElement('option');
            option.value = car.id;
            option.text = `${car.brand} ${car.model} (${car.plateNumber})`;
            carSelect.appendChild(option);
        });
    });
</script>