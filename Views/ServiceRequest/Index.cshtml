@model List<StoRvStar.Models.Entities.ServiceRequest>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Список заявок</h2>

        <a href="/ServiceRequest/Create" class="btn btn-primary">
            + Нова заявка
        </a>
    </div>

    <table class="table table-bordered table-hover shadow">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Клієнт</th>
                <th>Авто</th>
                <th>Послуги</th>
                <th>Сума</th>
                <th>Статус</th>
                <th>Дата</th>
                <th>Дії</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Id</td>

                    <td>
                        @r.User?.Name <br />
                        <small>@r.User?.Phone</small>
                    </td>

                    <td>
                        <b>@r.Car?.Brand @r.Car?.Model</b><br />
                        <small>@r.Car?.PlateNumber</small>
                    </td>

                    <td>
                        @foreach (var item in r.ServiceItems)
                        {
                            <span class="badge bg-secondary me-1">
                                @item.Service?.Name
                            </span>
                        }
                    </td>

                    <td>
                        <span class="fw-bold text-success">
                            @($"{r.TotalPrice} грн")
                        </span>
                    </td>

                    <td>
                        @{
                            string statusClass = r.Status switch
                            {
                                "New" => "bg-primary",
                                "InProgress" => "bg-warning text-dark",
                                "Done" => "bg-success",
                                _ => "bg-secondary"
                            };
                        }

                        <span class="badge @statusClass">
                            @r.Status
                        </span>
                    </td>

                    <td>
                        @r.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                    </td>

                    <td>
                        <!--статус-->
                        @if (r.Status == "New")
                        {
                            <a href="/ServiceRequest/UpdateStatus?id=@r.Id&status=InProgress"
                               class="btn btn-sm btn-warning mb-1">
                                В роботу
                            </a>
                        }
                        else if (r.Status == "InProgress")
                        {
                            <a href="/ServiceRequest/UpdateStatus?id=@r.Id&status=Done"
                               class="btn btn-sm btn-success mb-1">
                                Завершити
                            </a>
                        }
                        else
                        {
                            <div class="text-muted mb-1">Готово</div>
                        }

                        <!--EDIT-->
                        <a href="/ServiceRequest/Edit/@r.Id"
                           class="btn btn-sm btn-outline-primary mb-1">
                           Редагувати
                        </a>

                        <!--DELETE-->
                        <a href="/ServiceRequest/Delete/@r.Id"
                           class="btn btn-sm btn-online-danger"
                           onclick="return confirm('Видалити заявку?')">
                           Видалити
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>