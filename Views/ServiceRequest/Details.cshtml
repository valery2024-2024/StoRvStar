@model StoRvStar.Models.Entities.ServiceRequest

<div class="container mt-4">

    <h2 class="mb-4">Деталі заявки №@Model.Id</h2>

    <div class="card shadow p-4">

        <div class="row">

            <div class="col-md-6">
                <h5>Клієнт</h5>
                <p>
                    <b>@Model.User?.Name</b><br />
                       @Model.User?.Phone
                </p>
            </div>

            <div class="col-md-6">
                <h5>Авто</h5>
                <p>
                    <b>@Model.Car?.Brand @Model.Car?.Model</b><br />
                       @Model.Car?.PlateNumber
                </p>
            </div>

        </div>

        <hr />

        <h5>Послуги</h5>

        <table class="table table-bordered mt-2">
            <thead class="table-dark">
                <tr>
                    <th>Назва</th>
                    <th>Ціна</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.ServiceItems)
                {
                    <tr>
                        <td>@item.Service?.Name</td>
                        <td>@item.Price грн</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-3">
            <h4 class="text-success">
                Загальна сума: @Model.TotalPrice грн
            </h4>
        </div>

        <hr />
        @{
            string statusText = Model.Status switch
            {
                "New" => "Нова",
                "InProgress" => "В роботі",
                "Done" => "Готово",
                _ => Model.Status
            };

            string statusClass = Model.Status switch
            {
                "New" => "bg-primary",
                "InProgress" => "bg-warning text-dark",
                "Done" => "bg-success",
                 _ => "bg-secondary"
            };
        }

        <p>
            <b>Статус:</b>
            <span class="badge @statusClass">
                @statusText
            </span>
        </p>

        <p>
            <b>Опис:</b><br />
            @Model.Description
        </p>

        <p>
            <b>Дата:</b>
            @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
        </p>

        <a href="/ServiceRequest" class="btn btn-secondary mt-3">
            Назад
        </a>

    </div>

</div>